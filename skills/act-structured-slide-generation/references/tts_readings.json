{
  "$comment": "話し言葉として読み上げられる表記へ開くための表。speaker_notes(トークスクリプト)だけに適用する — スライド表示テキストは記号のままでよい(目で読むため)。載せるのは『TTSがそのままでは読めない/読み違える』ものだけ — 数字・桁区切り・%・単位語のように普通に読み上げられるものは開かない(過剰な変換は発表者が自分のメモを読めなくする)。原則は talk-script-and-tts.md、正しい読みは文脈が決めるので判断は書き手に残す。",
  "policy": {
    "scope": "speaker_notes only",
    "principle": "TTSが読み違える表記だけを開く。人が声に出して読んだときに自然な語を選ぶ(過剰なカタカナ化はしない)",
    "script_choice": {
      "operator_or_relation": "ひらがな・漢字で開く(かける / 割る / から / およそ)。記号のまま残さない",
      "unit": "カタカナまたは漢字(パーセント / 円 / 倍 / ポイント)",
      "ratio_or_fraction": "漢字の語順に直す(1/3 → 3分の1、A対B → AたいB)",
      "acronym_letterwise": "英字のまま可(KPI・ARR・ROI のようにアルファベット読みされる語)",
      "acronym_wordlike": "定着したカタカナへ(SaaS → サース、AI → エーアイ)",
      "english_word": "カタカナへ(Digital Human → デジタルヒューマン)。固有名詞は初出でカタカナ読みを添える",
      "number": "そのまま(桁区切りは読み上げられる)。単位記号だけを開く"
    }
  },
  "symbols": [
    {
      "pattern": "→",
      "readings": [
        "から",
        "へ"
      ],
      "kind": "operator_or_relation",
      "note": "推移・範囲。「2025年→2040年」は「2025年から2040年へ」"
    },
    {
      "pattern": "↑",
      "readings": [
        "上昇",
        "増加"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "↓",
      "readings": [
        "低下",
        "減少"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "×",
      "readings": [
        "かける",
        "倍"
      ],
      "kind": "operator_or_relation",
      "note": "掛け算か「n倍」かは文脈で選ぶ"
    },
    {
      "pattern": "÷",
      "readings": [
        "割る"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "±",
      "readings": [
        "プラスマイナス"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "≒",
      "readings": [
        "およそ",
        "約"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "≠",
      "readings": [
        "ではない"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "≥",
      "readings": [
        "以上"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "≤",
      "readings": [
        "以下"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "〜",
      "readings": [
        "から"
      ],
      "kind": "operator_or_relation",
      "note": "範囲。「960万〜2.16億円」は「960万円から2億1600万円」"
    },
    {
      "pattern": "~",
      "readings": [
        "から"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "＋",
      "readings": [
        "プラス",
        "と"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "＝",
      "readings": [
        "イコール",
        "は"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "▲",
      "readings": [
        "マイナス"
      ],
      "kind": "operator_or_relation",
      "note": "会計の負値"
    },
    {
      "pattern": "△",
      "readings": [
        "マイナス"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "▼",
      "readings": [
        "減"
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "／",
      "readings": [
        "と",
        "または",
        "分の"
      ],
      "kind": "ratio_or_fraction",
      "note": "並列か分数かを文脈で選ぶ"
    },
    {
      "pattern": "──",
      "readings": [
        ""
      ],
      "kind": "operator_or_relation",
      "note": "ダッシュは読み上げられない。文を切るか接続詞に置き換える"
    },
    {
      "pattern": "—",
      "readings": [
        ""
      ],
      "kind": "operator_or_relation"
    },
    {
      "pattern": "&",
      "readings": [
        "アンド"
      ],
      "kind": "operator_or_relation"
    }
  ],
  "patterns": [
    {
      "regex": "(?<![0-9A-Za-z])([0-9]+)\\s*/\\s*([0-9]+)(?![0-9])",
      "kind": "ratio_or_fraction",
      "hint": "分数は「{2}分の{1}」の語順で読む(1/3 → 3分の1)"
    },
    {
      "regex": "(?<![0-9A-Za-z])([0-9.]+)x(?![0-9A-Za-z])",
      "kind": "unit",
      "hint": "「{1}倍」と読む(2.4x → 2.4倍)"
    },
    {
      "regex": "(?<![A-Za-z])vs\\.?(?![A-Za-z])",
      "kind": "english_word",
      "hint": "「対」または「と比べて」と読む"
    },
    {
      "regex": "(?<![A-Za-z])(YoY|QoQ|MoM)(?![A-Za-z])",
      "kind": "acronym_wordlike",
      "hint": "「前年同期比」「前四半期比」「前月比」と読む"
    },
    {
      "regex": "(?<![A-Za-z])(CAGR)(?![A-Za-z])",
      "kind": "acronym_wordlike",
      "hint": "「年平均成長率」と読む(略語のままでは読み上げられない)"
    },
    {
      "regex": "(?<![A-Za-z])(SaaS|PaaS|IaaS)(?![A-Za-z])",
      "kind": "acronym_wordlike",
      "hint": "「{1}」はカタカナで読む(SaaS→サース、PaaS→パース、IaaS→イアース)"
    },
    {
      "regex": "(?<![A-Za-z])(e\\.g\\.|i\\.e\\.|etc\\.)",
      "kind": "english_word",
      "hint": "「たとえば」「つまり」「など」と日本語で読む"
    }
  ]
}
