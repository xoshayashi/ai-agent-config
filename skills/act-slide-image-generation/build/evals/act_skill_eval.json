{
  "runtime_scan_globs": ["SKILL.md", "build/references/*.md", "build/scripts/*.py"],
  "forbidden_patterns": [
    {"pattern": "#[0-9A-Fa-f]{6}", "reason": "Active prose and prompt code use semantic color roles; palette hex values live only in design-tokens.json."},
    {"pattern": "\\b(Honey|Petrol)\\b", "reason": "Active guidance uses stable semantic roles instead of palette-specific brand names."}
  ],
  "required_skill_phrases": [
    "name: act-slide-image-generation",
    "gpt-image-2",
    "equity_story_master",
    "top=50px right=72px bottom=17px left=72px",
    "H1 uses `x=72 y=50 w=1492`",
    "Subtitle uses `x=72 y=123 w=1492`",
    "Both modes pass 78-92% primary-body width",
    "Footer-absent slides pass 82-94% body height",
    "argument_closure_lock",
    "deck_argument_plan",
    "closure_matrix",
    "zero unstated decision-critical premises",
    "16-column parent grid",
    "consulting_grid_rigidity_lock",
    "seven image-model gates",
    "model_fit_plan",
    "clarity_first_composition_lock",
    "luminous_tone_vocabulary_lock",
    "edge registration >=90%",
    "grid-rigidity score >=0.93",
    "flex main-axis fill at 92-100%",
    "58-62% of the full canvas height in both modes",
    "footer_absent_vertical_balance_lock",
    "lowest meaningful body or allocation pixel within `y=857..869`",
    "28pt/700",
    "20pt/400",
    "47-50px",
    "33-35px",
    "within 2px",
    "source_plan",
    "reference_class: external_publication",
    "begins exactly with `Source: `",
    "Assumption: ` and one `Note: `",
    "x=72 y=866 w=1528 h=48",
    "message_box_plan",
    "zero icon children",
    "x=72 y=796 w=1528 h=73",
    "one centered 17pt line",
    "design-tokens.json",
    "--design-tokens PATH",
    "source_line: none",
    "slides_final/",
    "speaker_notes.json",
    "review_manifest"
  ],
  "helper_checks": [
    {
      "name": "deck_plan_2k",
      "args": ["--mode", "deck-plan", "--size", "2048x1152"],
      "expect_exit": 0,
      "must_contain": ["non_negotiable_canvas_contract", "composition_clarity", "78-92%", "argument_closure_lock", "deck_argument_plan", "closure_matrix", "grid_contract", "flex_contract", "layout_tree_gate", "consulting_grid_rigidity", "58-62%", "source_contract", "message_box_contract", "Source: "],
      "must_not_contain": ["density_tier", "layout_diversity_plan", "mece_support_gate", "0-2 purposeful"]
    },
    {
      "name": "text_structure_2k",
      "args": ["--mode", "text-structure", "--size", "2048x1152"],
      "expect_exit": 0,
      "must_contain": ["non_negotiable_canvas_contract", "composition_clarity", "78-92%", "argument_closure_lock", "deck_argument_plan", "closure_matrix", "grid_contract", "flex_contract", "layout_tree_gate", "consulting_grid_rigidity", "58-62%", "source_contract", "message_box_contract", "Source: "],
      "must_not_contain": ["density_tier", "layout_diversity_plan", "mece_support_gate", "0-2 purposeful"]
    },
    {
      "name": "single_slide_prompt",
      "args": ["--mode", "single-slide-image", "--archetype", "content-led composition", "--grid-mode", "content-led alignment", "--layout-plan", "build/evals/sample-layout-plan.json", "--size", "2048x1152"],
      "expect_exit": 0,
      "must_contain": ["ACT slide image generation contract", "DELIVERABLE", "MESSAGE", "CANVAS", "LAYOUT MAP", "EXACT COPY", "VISUAL SYSTEM", "PRESERVATION STATE", "ACCEPTANCE", "compiled_render_plan", "output_basis", "occurrences=1", "#FCFCFB", "visible glyph height 58-61px", "visible glyph height 40-43px", "source_plan=", "message_box_plan=", "Source: ", "text-only"],
      "must_not_contain": ["density_tier", "layout_family", "mece_support_gate", "icon_density_budget"]
    },
    {
      "name": "repair_prompt",
      "args": ["--mode", "repair", "--archetype", "preserve composition", "--grid-mode", "preserve alignment", "--layout-plan", "build/evals/sample-layout-plan.json"],
      "expect_exit": 0,
      "must_contain": ["Edit the first referenced target image", "preserve approved elements", "PRESERVATION STATE", "EXACT COPY"],
      "must_not_contain": ["UNRESOLVED"]
    },
    {
      "name": "single_slide_requires_resolved_composition",
      "args": ["--mode", "single-slide-image", "--layout-plan", "build/evals/sample-layout-plan.json"],
      "expect_exit": 1,
      "must_contain": ["Describe the content-led composition intent and composition-specific Grid/Flex nesting intent"],
      "must_not_contain": ["ACT slide image generation contract"]
    },
    {
      "name": "single_slide_requires_layout_plan",
      "args": ["--mode", "single-slide-image", "--archetype", "content-led composition", "--grid-mode", "hybrid Grid/Flex"],
      "expect_exit": 1,
      "must_contain": ["Provide --layout-plan with a validated Grid/Flex layout plan"],
      "must_not_contain": ["ACT slide image generation contract"]
    },
    {
      "name": "reject_non_2k_16x9_generation",
      "args": ["--mode", "deck-plan", "--size", "2560x1440"],
      "expect_exit": 1,
      "must_contain": ["only supports 16:9 gpt-image-2 sizes: 2048x1152"],
      "must_not_contain": []
    }
  ]
}
