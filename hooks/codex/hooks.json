{
  "hooks": {
    "SessionStart": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc '[ \"${AI_AGENT_HOOKS_ENABLE_MULTILLM_ORCHESTRATION:-0}\" = \"1\" ] || exit 0; python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/multillm_orchestrator.py\" --current codex'",
            "timeout": 25,
            "statusMessage": "Loading orchestration state"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_llm_config_managed": true,
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/safe_delete_guard.py\" --current codex",
            "timeout": 10,
            "statusMessage": "Checking shell command safety"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'if [ \"${AI_AGENT_HOOKS_ENABLE_MULTILLM_ORCHESTRATION:-0}\" = \"1\" ]; then exec python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/multillm_orchestrator.py\" --current codex; elif [ \"${AI_AGENT_HOOKS_ENABLE_RESPONSE_STRATEGY:-0}\" = \"1\" ]; then exec python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/response_strategy_bridge.py\" --current codex; else exit 0; fi'",
            "timeout": 150,
            "statusMessage": "Evaluating Codex post-response flow"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc '[ \"${AI_AGENT_HOOKS_ENABLE_MULTILLM_ORCHESTRATION:-0}\" = \"1\" ] || exit 0; exec python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/multillm_orchestrator.py\" --current codex'",
            "timeout": 60,
            "statusMessage": "Preparing Codex orchestration"
          }
        ]
      }
    ]
  }
}
