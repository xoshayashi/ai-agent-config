{
  "hooks": {
    "SessionStart": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CODEX_HOME:-$HOME/.codex}/hooks/scripts/self_workflow.py\" --current codex",
            "timeout": 25,
            "statusMessage": "Loading self-workflow state"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_llm_config_managed": true,
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CODEX_HOME:-$HOME/.codex}/hooks/scripts/safe_delete_guard.py\" --current codex",
            "timeout": 10,
            "statusMessage": "Checking shell command safety"
          }
        ]
      }
    ],
    "Stop": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CODEX_HOME:-$HOME/.codex}/hooks/scripts/self_workflow.py\" --current codex",
            "timeout": 50,
            "statusMessage": "Evaluating self-workflow continuation"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CODEX_HOME:-$HOME/.codex}/hooks/scripts/self_workflow.py\" --current codex",
            "timeout": 60,
            "statusMessage": "Preparing self-workflow brief"
          }
        ]
      }
    ]
  }
}
