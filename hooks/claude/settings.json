{
  "hooks": {
    "PreToolUse": [
      {
        "_llm_config_managed": true,
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/safe_delete_guard.py\" --current claude",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc '[ \"${AI_AGENT_HOOKS_ENABLE_RESPONSE_STRATEGY:-0}\" = \"1\" ] || exit 0; python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/response_strategy_bridge.py\" --current claude'",
            "timeout": 50
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc '[ \"${AI_AGENT_HOOKS_ENABLE_RESPONSE_STRATEGY:-0}\" = \"1\" ] || exit 0; python3 \"${AI_AGENT_HOOKS_RUNTIME_LINK:-$HOME/.llm-config/hooks}/scripts/response_strategy_bridge.py\" --current claude'",
            "timeout": 50
          }
        ]
      }
    ]
  }
}
