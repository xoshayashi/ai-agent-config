{
  "hooks": {
    "PreToolUse": [
      {
        "_llm_config_managed": true,
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CLAUDE_HOME:-$HOME/.claude}/hooks/scripts/safe_delete_guard.py\" --current claude",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CLAUDE_HOME:-$HOME/.claude}/hooks/scripts/self_workflow.py\" --current claude",
            "timeout": 50
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CLAUDE_HOME:-$HOME/.claude}/hooks/scripts/self_workflow.py\" --current claude",
            "timeout": 40
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "_llm_config_managed": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AI_AGENT_CLAUDE_HOME:-$HOME/.claude}/hooks/scripts/self_workflow.py\" --current claude",
            "timeout": 50
          }
        ]
      }
    ]
  }
}
