{
  "hooks": {
    "BeforeTool": [
      {
        "_ai_agent_config_managed": true,
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "ai-agent-config-safe-delete-guard",
            "type": "command",
            "command": "python3 \"${AI_AGENT_GEMINI_HOME:-$HOME/.gemini}/hooks/scripts/safe_delete_guard.py\" --current gemini",
            "timeout": 10000,
            "description": "Block permanent shell deletion commands and suggest the safer trash workflow."
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "_ai_agent_config_managed": true,
        "matcher": "*",
        "hooks": [
          {
            "name": "ai-agent-config-subprocess-check",
            "type": "command",
            "command": "python3 \"${AI_AGENT_GEMINI_HOME:-$HOME/.gemini}/hooks/scripts/subprocess_check.py\" --current gemini",
            "timeout": 200000,
            "description": "Ask the same-CLI subprocess advisor for the next step or completion signal."
          }
        ]
      }
    ]
  }
}
